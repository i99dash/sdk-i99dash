{
  "name": "i99dash-example-nextjs",
  "version": "0.2.1",
  "private": true,
  "description": "Next.js 15 example for the consolidated `i99dash` package. Demonstrates getContext, callApi, EN/AR + RTL, and driving-state awareness, all runnable offline via the dev-server (`i99dash dev`).",
  "type": "module",
  "scripts": {
    "dev": "next build && i99dash dev",
    "dev:next": "next dev --port 3200",
    "build": "next build",
    "validate": "i99dash validate",
    "publish": "i99dash publish",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "clean": "rimraf .next out .turbo"
  },
  "dependencies": {
    "i99dash": "^3.0.0",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
