{
  "name": "i99dash",
  "version": "1.8.0",
  "description": "Developer SDK + CLI for i99dash mini-apps. Runtime client, admin client, and the i99dash command in one install.",
  "license": "MIT",
  "homepage": "https://github.com/i99dash/i99dash-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i99dash/i99dash-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/i99dash/i99dash-sdk/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./dev-server": {
      "types": "./dist/dev-server.d.ts",
      "import": "./dist/dev-server.js",
      "require": "./dist/dev-server.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "bin": {
    "i99dash": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "MIGRATING.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "bash .githooks/install.sh 2>/dev/null || true",
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:category-drift": "node scripts/check-category-drift.mjs",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^3.25.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "fast-glob": "^3.3.3",
    "fastify": "^5.8.5",
    "image-size": "^2.0.2",
    "open": "^11.0.0",
    "tar": "^7.5.13",
    "undici": "^8.2.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@10.22.0"
}
